# =============================================================================
# .env.example  —  Copy to .env and fill in your values
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=http://localhost

# ── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=jurnal_user
DB_PASSWORD=ChangeMe_DbPass123!
DB_NAME=jurnal_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=ChangeMe_Redis456!
REDIS_DB=0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=ChangeMe_SuperLongJwtSecretKey_AtLeast32Chars!
JWT_REFRESH_SECRET=ChangeMe_SuperLongRefreshSecretKey_AtLeast32Chars!

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@jurnalapp.id

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api